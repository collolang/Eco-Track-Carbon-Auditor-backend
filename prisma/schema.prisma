// prisma/schema.prisma
// EcoTrack Database Schema
// Database: PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}
// ─────────────────────────────────────────────
// USER MODEL
// ─────────────────────────────────────────────
model User {
  id           String   @id @default(cuid())
  firstName    String
  lastName     String
  email        String   @unique
  passwordHash String
  role         Role     @default(USER)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  company       Company?
  emissionEntries EmissionEntry[]
  refreshTokens RefreshToken[]

  @@map("users")
}

enum Role {
  USER
  ADMIN
}

// ─────────────────────────────────────────────
// REFRESH TOKEN MODEL
// ─────────────────────────────────────────────
model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

// ─────────────────────────────────────────────
// COMPANY MODEL
// ─────────────────────────────────────────────
model Company {
  id                  String   @id @default(cuid())
  userId              String   @unique
  businessName        String
  industryType        IndustryType @default(OTHER)
  location            String?
  country             String   @default("kenya")
  numberOfEmployees   Int      @default(1)
  registrationNumber  String?
  contactEmail        String?
  contactPhone        String?
  businessDescription String?
  yearEstablished     String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Relations
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  emissionEntries EmissionEntry[]

  @@map("companies")
}

enum IndustryType {
  RETAIL
  MANUFACTURING
  TECHNOLOGY
  HEALTHCARE
  EDUCATION
  HOSPITALITY
  TRANSPORTATION
  CONSTRUCTION
  AGRICULTURE
  ENERGY
  FINANCIAL_SERVICES
  CONSULTING
  REAL_ESTATE
  MEDIA
  OTHER
}

// ─────────────────────────────────────────────
// EMISSION ENTRY MODEL
// Core data table: stores each monthly submission
// ─────────────────────────────────────────────
model EmissionEntry {
  id        String   @id @default(cuid())
  userId    String
  companyId String?
  month     Int      // 1-12
  year      Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Scope 1 - Direct Emissions
  fuelType     FuelType? 
  fuelQuantity Float?    // litres or kg depending on fuel type

  // Scope 2 - Purchased Electricity
  electricityKwh Float?  // kWh

  // Scope 3 - Indirect
  wasteKg      Float?    // kg of waste
  wasteType    WasteType @default(LANDFILL)
  flightKm     Float?    // business travel km

  // Calculated totals (stored for performance)
  scope1Emissions Float @default(0)  // kg CO2e
  scope2Emissions Float @default(0)  // kg CO2e
  scope3Emissions Float @default(0)  // kg CO2e
  totalEmissions  Float @default(0)  // kg CO2e

  // Notes
  notes String?

  // Relations
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@unique([userId, month, year]) // One entry per user per month
  @@map("emission_entries")
}

enum FuelType {
  PETROL
  DIESEL
  KEROSENE
  LNG
  CNG
  LPG
  WOOD
  COAL
}

enum WasteType {
  LANDFILL
  RECYCLED
  COMPOSTED
  INCINERATED
  HAZARDOUS
}
